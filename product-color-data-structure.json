  "apiEndpoints": {
    "getProduct": {
      "method": "GET",
      "url": "/api/products/:productId",
      "description": "Get complete product data with all color variants"
    },
    "getProductColors": {
      "method": "GET", 
      "url": "/api/products/:productId/colors",
      "description": "Get only color variants for a product"
    },
    "checkAvailability": {
      "method": "GET",
      "url": "/api/products/:productId/colors/:colorKey/availability",
      "description": "Check real-time availability for specific color"
    },
    "updateStock": {
      "method": "PUT",
      "url": "/api/products/:productId/colors/:colorKey/stock",
      "description": "Update stock count for specific color variant"
    }
  },
  "databaseSchema": {
    "mongodb": {
      "collection": "products",
      "indexes": [
        { "productId": 1 },
        { "category": 1, "subcategory": 1 },
        { "colors.sku": 1 },
        { "tags": 1 },
        { "basePrice": 1 }
      ],
